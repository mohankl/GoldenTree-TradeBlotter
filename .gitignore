# ---- .NET ----
bin/
obj/
*.user
# SQLite database files (created at runtime)
*.db
*.db-shm
*.db-wal

# ---- Node / Vite ----
# Trailing slash: ignore real node_modules directories, but NOT the
# tests/frontend/node_modules symlink that bridges to frontend/node_modules.
node_modules/
dist/
.vite/
*.local
# TypeScript incremental build cache (regenerated by vue-tsc on every build).
*.tsbuildinfo

# ---- Playwright ----
test-results/
playwright-report/
blob-report/
.playwright/

# ---- Editor / OS ----
.DS_Store
.vscode/
.idea/
*.swp

# ---- Agent scratch ----
.claude/
.playwright-mcp/
